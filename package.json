{
  "name": "@automatelab/n8n-mcp",
  "version": "0.3.0",
  "mcpName": "io.github.ratamaha-git/n8n-mcp",
  "description": "MCP server for n8n with tools for generating workflows, linting, diagnosing failed executions, and driving live n8n instances. Built for AI agents.",
  "type": "module",
  "bin": {
    "n8n-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "smoke": "node ./dist/index.js --smoke",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "n8n",
    "mcp",
    "cursor",
    "claude",
    "gemini",
    "gemini-cli-extension",
    "agent-skill",
    "model-context-protocol",
    "workflow-automation",
    "langchain",
    "ai-agent"
  ],
  "homepage": "https://automatelab.tech/n8n-mcp-server/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ratamaha-git/n8n-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ratamaha-git/n8n-mcp/issues"
  },
  "author": "AutomateLab <hello@automatelab.tech>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "action.yml",
    "dist/",
    "examples/",
    "references/",
    "SKILL.md",
    "GEMINI.md",
    "gemini-extension.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
